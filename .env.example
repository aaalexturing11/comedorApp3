# Copia este archivo a .env y completa los valores para el formulario de contacto.

# Correo donde llegan los mensajes del sitio
CONTACT_TO_EMAIL=unete@comedordelospobres.org

# Remitente (debe ser una cuenta autorizada en tu proveedor SMTP)
CONTACT_FROM_EMAIL=unete@comedordelospobres.org

# SMTP (Gmail con contraseña de aplicación, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-contraseña-de-aplicacion
