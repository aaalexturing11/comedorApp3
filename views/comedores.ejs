<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head', { 
        title: 'Nuestros Comedores - Comedor de los Pobres', 
        description: 'Conoce nuestras 4 sedes: Escobedo, García, Guadalupe y Juárez. Brindamos alimento y esperanza a quienes más lo necesitan.' 
    }) %>
    <style>
        :root {
            --morado: #7c3aed;
            --amarillo: #fbbf24;
            --naranja: #f97316;
        }

        /* Hero Ultra Moderno */
        .hero-visual {
            background: linear-gradient(135deg, #c27bf8 0%, #946ed6 100%);
            min-height: 35vh;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
            border-radius: 0 0 4rem 4rem;
            box-shadow: 0 10px 30px rgba(124, 58, 237, 0.25);
            border-bottom: 1px solid rgba(124, 58, 237, 0.1);
        }

        .hero-pattern {
            position: absolute;
            inset: 0;
            opacity: 0.1;
            background-image: radial-gradient(#ffffff 1px, transparent 1px);
            background-size: 30px 30px;
        }

        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            grid-auto-rows: 240px;
            gap: 1.5rem;
        }

        .gallery-item:nth-child(2) { grid-column: span 2; }
        .gallery-item:nth-child(3) { grid-row: span 2; }

        @media (max-width: 768px) {
            .gallery-grid { grid-template-columns: 1fr; grid-auto-rows: 250px; }
            .gallery-item { grid-column: span 1 !important; grid-row: span 1 !important; }
        }

        .accent-border {
            border-left: 6px solid var(--naranja);
        }

        .tab-content {
            display: none;
            opacity: 0;
            transition: opacity 0.5s ease;
        }

        .tab-content.active {
            display: block;
            opacity: 1;
        }

        .tab-btn {
            transition: all 0.3s ease;
        }

        .tab-btn.active {
            background-color: white;
            color: var(--morado);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }
    </style>
</head>
