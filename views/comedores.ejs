    <!-- SCRIPT TABS -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const tabs = document.querySelectorAll('.tab-btn');
            const contents = document.querySelectorAll('.tab-content');

            tabs.forEach(tab => {
                tab.addEventListener('click', () => {
                    // Remover active de todos los tabs y ocultar contenido
                    tabs.forEach(t => t.classList.remove('active', 'bg-white', 'text-purple-900', 'shadow-sm'));
                    tabs.forEach(t => t.classList.add('text-gray-500'));
                    contents.forEach(c => c.classList.remove('active'));

                    // Agregar active al tab seleccionado
                    tab.classList.add('active', 'bg-white', 'text-purple-900', 'shadow-sm');
                    tab.classList.remove('text-gray-500');

                    // Mostrar contenido correspondiente
                    const targetId = tab.getAttribute('data-target');
                    document.getElementById(targetId).classList.add('active');
                });
            });
        });
    </script>

