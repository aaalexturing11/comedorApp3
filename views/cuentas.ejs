<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head', { 
        title: 'Comedor de los Pobres - Cuentas', 
        description: 'Cuentas bancarias e información para realizar donativos a la Asociación Juan XXIII - Comedor de los Pobres.' 
    }) %>
    <style>
        .hero-simple {
            background: linear-gradient(135deg, #f5f3ff 0%, #ffffff 100%);
            border-radius: 0 0 4rem 4rem;
            box-shadow: 0 10px 30px rgba(124, 58, 237, 0.05);
            border-bottom: 1px solid rgba(124, 58, 237, 0.04);
        }

        .bank-card {
            background: white;
            padding: 2.5rem;
            border-radius: 2.5rem;
            border: 1px solid rgba(0,0,0,0.03);
            transition: all 0.4s ease;
            box-shadow: 0 10px 30px rgba(0,0,0,0.02);
        }

        .bank-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(124, 58, 237, 0.08);
        }

        .copy-badge {
            background: #f8fafc;
            border: 1px dashed #e2e8f0;
            padding: 0.5rem 1rem;
            border-radius: 0.75rem;
            font-family: monospace;
            font-size: 0.9rem;
            color: #475569;
        }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <%- include('partials/navbar') %>

    <!-- HERO -->
    <header class="hero-simple pt-20 pb-24 text-center">
        <div class="max-w-4xl mx-auto px-6">
            <span class="text-orange-500 font-black text-[10px] uppercase tracking-widest mb-4 block">Apoyo Económico</span>
            <h1 class="text-4xl md:text-5xl font-black text-purple-900 mb-6">Cuentas Bancarias</h1>
            <p class="text-gray-500 text-lg leading-relaxed max-w-2xl mx-auto">
                Tu apoyo nos ayuda a comprar la materia prima para la preparación de los alimentos y el sostenimiento de nuestra obra social.
            </p>
        </div>
    </header>

    <!-- SECCIÓN DE CUENTAS -->
    <section class="pt-16 pb-12">
        <div class="max-w-7xl mx-auto px-6">
            
            <!-- Datos Fiscales Generales -->
            <div class="max-w-3xl mx-auto mb-16 bg-white p-8 rounded-[2rem] border border-purple-50 text-center shadow-sm">
                <h2 class="text-purple-900 font-black text-xl mb-4">Información para Donativos</h2>
                <div class="flex flex-col md:flex-row justify-center gap-6 items-center">
                    <div class="text-sm">
                        <span class="text-gray-400 block uppercase text-[10px] font-bold tracking-widest mb-1">Titular</span>
                        <span class="font-bold text-gray-700">Juan XXIII al Servicio de los Pobres, A.C.</span>
                    </div>
                    <div class="hidden md:block w-px h-10 bg-gray-100"></div>
                    <div class="text-sm">
                        <span class="text-gray-400 block uppercase text-[10px] font-bold tracking-widest mb-1">RFC</span>
                        <span class="font-bold text-gray-700">JXS-691024-U2A</span>
                    </div>
                </div>
                <div class="mt-6 inline-flex items-center gap-2 px-4 py-2 bg-green-50 text-green-700 rounded-full text-xs font-bold">
                    <i class="fas fa-check-circle"></i>
                    Donataria autorizada (Recibos deducibles)
                </div>
            </div>

            <!-- Grid de Bancos -->
            <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
                
                <!-- Banco 1: BanBajío -->
                <div class="bank-card border-t-4 border-purple-500">
                    <div class="flex justify-between items-start mb-8">
                        <div class="w-12 h-12 bg-red-50 text-red-600 rounded-2xl flex items-center justify-center font-black text-xl italic">
                            B
                        </div>
                        <span class="text-[10px] font-black text-gray-300 uppercase tracking-widest">Opción 01</span>
                    </div>
                    <h3 class="text-2xl font-black text-purple-900 mb-6 tracking-tight">BanBajío</h3>
                    
                    <div class="space-y-6">
                        <div>
                            <label class="text-[10px] font-black text-gray-400 uppercase block mb-2">Cuenta</label>
                            <div class="copy-badge">01459763-70201</div>
                        </div>
                        <div>
                            <label class="text-[10px] font-black text-gray-400 uppercase block mb-2">CLABE Interbancaria</label>
                            <div class="copy-badge">030580900006281824</div>
                        </div>
                    </div>
                </div>

                <!-- Banco 2: AFIRME -->
                <div class="bank-card border-t-4 border-green-500">
                    <div class="flex justify-between items-start mb-8">
                        <div class="w-12 h-12 bg-green-50 text-green-600 rounded-2xl flex items-center justify-center">
                            <i class="fas fa-university"></i>
                        </div>
                        <span class="text-[10px] font-black text-gray-300 uppercase tracking-widest">Opción 02</span>
                    </div>
                    <h3 class="text-2xl font-black text-purple-900 mb-6 tracking-tight">AFIRME</h3>
                    
                    <div class="space-y-6">
                        <div>
                            <label class="text-[10px] font-black text-gray-400 uppercase block mb-2">Cuenta</label>
                            <div class="copy-badge">101-118-754</div>
                        </div>
                        <div>
                            <label class="text-[10px] font-black text-gray-400 uppercase block mb-2">CLABE Interbancaria</label>
                            <div class="copy-badge">062580001011187547</div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Mensaje Final -->
            <div class="mt-20 text-center">
                <p class="text-gray-400 text-sm italic max-w-xl mx-auto">
                    "Después del verbo AMAR, el verbo AYUDAR es el más hermoso."
                </p>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <%- include('partials/footer') %>
</body>
</html>