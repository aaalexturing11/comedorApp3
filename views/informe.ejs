<!DOCTYPE html>
<html lang="es">

<head>
    <%- include('partials/head', { 
        title: 'Comedor de los Pobres - Informe', 
        description: 'Informe de Actividades y Resultados de la Asociación Juan XXIII. Conoce nuestro impacto y logros.' 
    }) %>
    <style>
        :root {
            --morado-main: #7c3aed;
            --naranja-accent: #f97316;
            --bg-clean: #fafafa;
        }
        html { scroll-behavior: smooth; }
        .hero-gradient {
            background: linear-gradient(135deg, #4c1d95 0%, #7c3aed 100%);
        }

        .card-shadow {
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
            transition: all 0.3s ease;
        }

        .card-shadow:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
        }

        .section-divider {
            height: 4px;
            width: 60px;
            background: var(--naranja-accent);
            margin: 1.5rem 0;
            border-radius: 2px;
        }

        .progress-bar {
            height: 8px;
            background: #e2e8f0;
            border-radius: 4px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: var(--morado-main);
        }

        .sidebar-item {
            border-left: 3px solid transparent;
            transition: all 0.3s ease;
        }

        .sidebar-item.active {
            border-left-color: var(--naranja-accent);
            background: #fff7ed;
            color: var(--naranja-accent);
        }

        .hero-report {
            background: linear-gradient(135deg, #f5f3ff 0%, #ffffff 100%);
            border-radius: 0 0 4rem 4rem;
            box-shadow: 0 10px 30px rgba(124, 58, 237, 0.05);
            border-bottom: 1px solid rgba(124, 58, 237, 0.04);
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <%- include('partials/navbar') %>


    <!-- PORTADA DEL INFORME -->
    <header class="hero-report pt-20 pb-24 text-center">
        <div class="max-w-4xl mx-auto px-6 relative z-10">
            <span class="text-orange-500 font-black text-[10px] uppercase tracking-widest mb-4 block">Transparencia y
                Resultados</span>
            <h1 class="text-4xl md:text-5xl font-black text-purple-900 mb-6">Informe Anual 2025</h1>
            <p class="text-gray-500 text-lg leading-relaxed max-w-2xl mx-auto mb-8">
                Comprometidos con la disminución de la pobreza alimentaria, compartimos los resultados y el impacto de
                nuestra labor durante este año.
            </p>
            <a href="/informe/Informe 2025.pdf" download="Informe-Anual-2025.pdf"
                class="inline-flex items-center px-8 py-3 bg-purple-600 text-white rounded-full font-black text-xs hover:bg-purple-700 transition shadow-lg shadow-purple-200">
                <i class="fas fa-file-pdf mr-2"></i> DESCARGAR REPORTE PDF
            </a>
        </div>
    </header>

    <!-- CONTENT WRAPPER -->
    <main class="max-w-7xl mx-auto px-6 pt-16 pb-12">
        <div class="grid lg:grid-cols-12 gap-16">

            <!-- SIDE NAVIGATION (Sub-menu) -->
            <aside class="hidden lg:block lg:col-span-3 sticky top-32 h-fit">
                <div class="bg-white rounded-3xl p-6 border border-gray-100 shadow-sm">
                    <h3 class="text-purple-900 font-black text-xs uppercase tracking-widest mb-6 pl-4">Contenido</h3>
                    <nav class="flex flex-col space-y-1">
                        <a href="#organizacion"
                            class="sidebar-item active p-4 text-sm font-bold rounded-xl flex items-center gap-3">
                            <i class="fas fa-sitemap w-5"></i> Organización
                        </a>
                        <a href="#impacto"
                            class="sidebar-item p-4 text-sm font-bold rounded-xl flex items-center gap-3 hover:bg-gray-50">
                            <i class="fas fa-chart-pie w-5"></i> Impacto
                        </a>
                        <a href="#programas"
                            class="sidebar-item p-4 text-sm font-bold rounded-xl flex items-center gap-3 hover:bg-gray-50">
                            <i class="fas fa-hand-holding-heart w-5"></i> Programas de Apoyo
                        </a>
                        <a href="#eventos"
                            class="sidebar-item p-4 text-sm font-bold rounded-xl flex items-center gap-3 hover:bg-gray-50">
                            <i class="fas fa-calendar-alt w-5"></i> Eventos
                        </a>
                        <a href="#mejoras"
                            class="sidebar-item p-4 text-sm font-bold rounded-xl flex items-center gap-3 hover:bg-gray-50">
                            <i class="fas fa-tools w-5"></i> Mantenimiento
                        </a>
                        <a href="#financiero"
                            class="sidebar-item p-4 text-sm font-bold rounded-xl flex items-center gap-3 hover:bg-gray-50">
                            <i class="fas fa-coins w-5"></i> Transparencia
                        </a>
                        <a href="#reconocimientos"
