                                </div>
                            </div>
                        </div>
                        <div class="bg-white p-6 rounded-3xl border border-gray-100 card-shadow">
                            <div class="flex items-start gap-4">
                                <i class="fas fa-map-marker-alt text-2xl text-orange-500 mt-1"></i>
                                <div>
                                    <h4 class="font-bold text-gray-900 text-lg">Comedor García</h4>
                                    <p class="text-sm text-gray-500 mt-1">Colima No. 101 Col. Alfonso Martínez
                                        Domínguez, García, N.L. 66006.</p>
                                </div>
                            </div>
                        </div>
                        <div class="bg-white p-6 rounded-3xl border border-gray-100 card-shadow">
                            <div class="flex items-start gap-4">
                                <i class="fas fa-map-marker-alt text-2xl text-orange-500 mt-1"></i>
                                <div>
                                    <h4 class="font-bold text-gray-900 text-lg">Comedor Guadalupe</h4>
                                    <p class="text-sm text-gray-500 mt-1">Brígida García No. 115 Sur Col. Jardines de
                                        Casa Blanca, Guadalupe, N.L. 67116.</p>
                                </div>
                            </div>
                        </div>
                        <div class="bg-white p-6 rounded-3xl border border-gray-100 card-shadow">
                            <div class="flex items-start gap-4">
                                <i class="fas fa-map-marker-alt text-2xl text-orange-500 mt-1"></i>
                                <div>
                                    <h4 class="font-bold text-gray-900 text-lg">Comedor Juárez</h4>
                                    <p class="text-sm text-gray-500 mt-1">Centro Comunitario Arboledas de los Naranjos,
                                        Lomas de Francia S/N, Juárez, N.L. 67280.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- 3. PROGRAMAS DE APOYO -->
