<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head', { 
        title: 'Donar - Comedor de los Pobres', 
        description: 'Tu generosidad alimenta la esperanza. Conoce las opciones de donativo vía transferencia bancaria y PayPal para la Asociación Juan XXIII.' 
    }) %>
    <style>
        .hero-donate {
            background: radial-gradient(circle at top right, rgba(254, 215, 170, 0.3) 0%, rgba(245, 243, 255, 0.4) 50%, rgba(255, 255, 255, 1) 100%),
                        linear-gradient(135deg, #f5f3ff 0%, #ffffff 100%);
            border-radius: 0 0 4rem 4rem;
            box-shadow: 0 10px 30px rgba(124, 58, 237, 0.05);
            border-bottom: 1px solid rgba(124, 58, 237, 0.04);
        }

        .method-tab {
            transition: all 0.3s ease;
        }

        .method-tab.active {
            background-color: #7c3aed;
            color: white;
            box-shadow: 0 10px 25px rgba(124, 58, 237, 0.25);
        }

        .method-tab:not(.active):hover {
            background-color: #f3f4f6;
            color: #1f2937;
        }

        .bank-card-premium {
            background: white;
            border-radius: 2.5rem;
            border: 1px solid rgba(124, 58, 237, 0.05);
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.02);
            transition: all 0.4s ease;
        }

        .bank-card-premium:hover {
            transform: translateY(-4px);
            box-shadow: 0 25px 50px rgba(124, 58, 237, 0.06);
        }

        .copy-badge-premium {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            padding: 0.75rem 1.25rem;
            border-radius: 1.25rem;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 1.05rem;
            color: #1e293b;
            font-weight: 700;
            letter-spacing: 0.05em;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.2s ease;
        }

        .copy-badge-premium:hover {
            border-color: #cbd5e1;
            background-color: #f1f5f9;
        }

        /* Toast notification styling */
        .toast-notification {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            background: #1e293b;
            color: white;
            padding: 1rem 1.5rem;
            border-radius: 1.25rem;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            display: flex;
            align-items: center;
            gap: 0.75rem;
            transform: translateY(150%);
            transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            z-index: 1000;
        }

        .toast-notification.show {
            transform: translateY(0);
        }
    </style>
</head>
<body class="bg-slate-50 text-gray-800">

    <!-- NAVBAR -->
    <%- include('partials/navbar') %>

    <!-- HERO / INTRODUCCIÓN PSICOLÓGICA -->
    <header class="hero-donate pt-20 pb-24 text-center relative overflow-hidden">
        <!-- Elementos de diseño flotantes sutiles -->
        <div class="absolute top-10 left-10 w-72 h-72 bg-purple-200/20 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute bottom-5 right-10 w-80 h-80 bg-orange-200/25 rounded-full blur-3xl pointer-events-none"></div>
        
        <div class="max-w-4xl mx-auto px-6 relative z-10">
            <span class="text-orange-500 font-black text-[10px] uppercase tracking-widest mb-4 inline-flex items-center gap-2 px-3 py-1 bg-orange-50 rounded-full">
                <i class="fas fa-heart text-orange-500 animate-pulse"></i> Tu impacto hoy
            </span>
            <h1 class="text-4xl md:text-5xl font-black text-purple-900 mb-6">
                Alimenta la Esperanza
            </h1>
            <p class="text-gray-500 text-lg leading-relaxed max-w-2xl mx-auto">
                Con tu donación compras la materia prima para preparar alimentos calientes y dignos. Cada aportación se traduce directamente en nutrición y amor para quien más lo necesita.
            </p>
        </div>
    </header>

    <!-- SECCIÓN PRINCIPAL DE DONACIÓN -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 pt-16 pb-12 relative z-20">
        
        <!-- MECANISMO DE SELECCIÓN DE MÉTODO DE PAGO (FUSIÓN PERFECTA) -->
        <!-- CONTENEDORES DE MÉTODOS DE PAGO (3 COLUMNAS SIMÉTRICAS) -->
        <section class="max-w-7xl mx-auto mb-16">
            <div class="text-center mb-12">
                <h2 class="text-3xl font-black text-purple-900">Métodos Oficiales de Donación</h2>
                <p class="text-gray-500 text-sm mt-1">Elige la opción que sea más práctica y cómoda para ti</p>
            </div>

            <!-- Datos Fiscales Generales (Compacto Horizontal) -->
            <div class="max-w-3xl mx-auto bg-white p-8 rounded-[2rem] border border-purple-50 text-center shadow-sm mb-12">
                <h2 class="text-purple-900 font-black text-xl mb-4">Información para Donativos</h2>
                <div class="flex flex-col md:flex-row justify-center gap-6 items-center">
                    <div class="text-sm">
                        <span class="text-gray-400 block uppercase text-[10px] font-bold tracking-widest mb-1">Titular</span>
                        <span class="font-bold text-gray-700">Juan XXIII al Servicio de los Pobres, A.C.</span>
                    </div>
                    <div class="hidden md:block w-px h-10 bg-slate-100"></div>
                    <div class="text-sm">
                        <span class="text-gray-400 block uppercase text-[10px] font-bold tracking-widest mb-1">RFC</span>
                        <span class="font-bold text-gray-700 flex items-center justify-center gap-2">
                            JXS-691024-U2A
                            <button onclick="copyToClipboard('JXS-691024-U2A', 'RFC')" class="text-purple-500 hover:text-purple-700 focus:outline-none" title="Copiar RFC">
                                <i class="far fa-copy text-xs"></i>
                            </button>
                        </span>
                    </div>
                </div>
                <div class="mt-6 inline-flex items-center gap-2 px-4 py-2 bg-green-50 text-green-700 rounded-full text-xs font-bold border border-green-100">
                    <i class="fas fa-check-circle text-green-600"></i>
                    Donataria autorizada (Recibos deducibles)
                </div>
            </div>

            <!-- GRID DE 3 COLUMNAS -->
            <div class="grid lg:grid-cols-3 gap-8 items-stretch max-w-7xl mx-auto">
                
                <!-- Tarjeta 1: BanBajío -->
                <div class="bank-card-premium p-8 relative overflow-hidden border-t-8 border-purple-500 flex flex-col justify-between">
                    <div class="absolute top-0 right-0 w-24 h-24 bg-purple-500/5 rounded-bl-full pointer-events-none"></div>
                    <div>
                        <div class="flex justify-between items-start mb-6">
                            <div class="w-12 h-12 bg-purple-50 text-purple-600 rounded-2xl flex items-center justify-center font-black text-xl italic shadow-inner">
                                B
                            </div>
                            <span class="text-[10px] font-black text-purple-400 bg-purple-50 px-2.5 py-1 rounded-full uppercase tracking-widest">Opción 01</span>
                        </div>
                        
                        <h3 class="text-2xl font-black text-purple-900 mb-6">BanBajío</h3>
                        
                        <div class="space-y-6">
                            <div>
                                <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest block mb-2">Número de Cuenta</label>
                                <div class="copy-badge-premium">
                                    <span>014 597 637 0201</span>
                                    <button onclick="copyToClipboard('0145976370201', 'Número de Cuenta (BanBajío)')" class="text-purple-500 hover:text-purple-700 ml-2 focus:outline-none" title="Copiar sin espacios">
                                        <i class="far fa-copy"></i>
                                    </button>
                                </div>
                            </div>
                            <div>
                                <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest block mb-2">CLABE Interbancaria</label>
                                <div class="copy-badge-premium">
                                    <span>030 580 9000 0628 1824</span>
                                    <button onclick="copyToClipboard('030580900006281824', 'CLABE (BanBajío)')" class="text-purple-500 hover:text-purple-700 ml-2 focus:outline-none" title="Copiar sin espacios">
                                        <i class="far fa-copy"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tarjeta 2: AFIRME -->
                <div class="bank-card-premium p-8 relative overflow-hidden border-t-8 border-green-500 flex flex-col justify-between">
                    <div class="absolute top-0 right-0 w-24 h-24 bg-green-500/5 rounded-bl-full pointer-events-none"></div>
                    <div>
                        <div class="flex justify-between items-start mb-6">
                            <div class="w-12 h-12 bg-green-50 text-green-600 rounded-2xl flex items-center justify-center shadow-inner">
                                <i class="fas fa-university text-lg"></i>
                            </div>
                            <span class="text-[10px] font-black text-green-600 bg-green-50 px-2.5 py-1 rounded-full uppercase tracking-widest">Opción 02</span>
                        </div>
                        
                        <h3 class="text-2xl font-black text-purple-900 mb-6">AFIRME</h3>
                        
                        <div class="space-y-6">
                            <div>
                                <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest block mb-2">Número de Cuenta</label>
                                <div class="copy-badge-premium">
                                    <span>101-118-754</span>
                                    <button onclick="copyToClipboard('101118754', 'Número de Cuenta (AFIRME)')" class="text-purple-500 hover:text-purple-700 ml-2 focus:outline-none" title="Copiar sin guiones">
                                        <i class="far fa-copy"></i>
                                    </button>
                                </div>
                            </div>
                            <div>
                                <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest block mb-2">CLABE Interbancaria</label>
                                <div class="copy-badge-premium">
                                    <span>062 580 0010 1118 7547</span>
                                    <button onclick="copyToClipboard('062580001011187547', 'CLABE (AFIRME)')" class="text-purple-500 hover:text-purple-700 ml-2 focus:outline-none" title="Copiar sin espacios">
                                        <i class="far fa-copy"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tarjeta 3: PayPal -->
                <div class="bank-card-premium p-8 relative overflow-hidden border-t-8 border-blue-500 flex flex-col justify-between">
                    <div class="absolute top-0 right-0 w-24 h-24 bg-blue-500/5 rounded-bl-full pointer-events-none"></div>
                    <div>
                        <div class="flex justify-between items-start mb-6">
                            <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center shadow-inner">
                                <i class="fab fa-paypal text-lg"></i>
                            </div>
                            <span class="text-[10px] font-black text-blue-600 bg-blue-50 px-2.5 py-1 rounded-full uppercase tracking-widest">Opción 03</span>
                        </div>
                        
                        <h3 class="text-2xl font-black text-purple-900 mb-4">PayPal</h3>
                        <p class="text-xs text-gray-500 leading-relaxed mb-6">
                            Donativo rápido con tu tarjeta de crédito, débito o saldo PayPal de manera segura y encriptada.
                        </p>
                        
                        <!-- Formulario de PayPal Oficial -->
                        <form action="https://www.paypal.com/cgi-bin/webscr" method="post" target="_blank" class="w-full mt-4">
                            <input type="hidden" name="cmd" value="_s-xclick">
                            <input type="hidden" name="hosted_button_id" value="4DESX3LB9LFRC">
                            
                            <button type="submit" 
                                    class="w-full py-3.5 bg-orange-500 text-white rounded-full font-black text-sm hover:bg-orange-600 transition shadow-lg shadow-orange-200 flex items-center justify-center gap-2 cursor-pointer">
                                Proceder al Pago Seguro <i class="fas fa-arrow-right text-xs"></i>
                            </button>
                        </form>
                    </div>

                    <div class="mt-6 pt-4 border-t border-slate-100 flex justify-center gap-4 text-[9px] font-bold text-gray-400 uppercase tracking-wider">
                        <span><i class="fas fa-lock text-green-500"></i> Conexión SSL</span>
                        <span>•</span>
                        <span><i class="fab fa-cc-visa"></i> Visa / MC / Amex</span>
                    </div>
                </div>

            </div>
        </section>

        <!-- SECCIÓN DE TRANSPARENCIA Y CONFIANZA -->
        <section class="max-w-4xl mx-auto mt-20 pt-12 border-t border-gray-100 text-center">
            <h3 class="text-xl font-black text-purple-900 mb-4">¿Tienes alguna duda o necesitas un Recibo Deducible?</h3>
            <p class="text-gray-500 text-sm max-w-lg mx-auto mb-8 leading-relaxed">
                Si requieres un comprobante fiscal para deducir impuestos en México, por favor envíanos tu comprobante de transferencia y datos fiscales por correo o WhatsApp.
            </p>
            <div class="flex flex-col sm:flex-row justify-center gap-4">
                <a href="https://wa.me/528130954567" target="_blank" 
                   class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white text-green-600 rounded-2xl border border-green-200 text-sm font-bold hover:bg-green-50/50 transition">
                    <i class="fab fa-whatsapp"></i> Reportar por WhatsApp
                </a>
                <a href="mailto:unete@comedordelospobres.org" 
                   class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white text-purple-600 rounded-2xl border border-purple-200 text-sm font-bold hover:bg-purple-50/50 transition">
                    <i class="far fa-envelope"></i> unete@comedordelospobres.org
                </a>
            </div>
        </section>

    </main>

    <!-- TESTIMONIO INSPIRACIONAL -->
    <section class="bg-purple-900 text-white py-20 px-6 mt-20 text-center relative overflow-hidden">
        <div class="max-w-3xl mx-auto relative z-10">
            <span class="text-orange-400 text-4xl block mb-6">“</span>
            <blockquote class="text-xl md:text-2xl font-medium italic leading-relaxed mb-6">
                "Después del verbo amar, el verbo ayudar es el más hermoso"
            </blockquote>
            <cite class="text-sm font-black uppercase tracking-widest text-orange-400 block">P. Roberto Infante</cite>
            <span class="text-xs text-purple-300 font-semibold block mt-1">Fundador de Comedor de los Pobres</span>
        </div>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-purple-800/60 via-purple-950 to-purple-950 opacity-40 pointer-events-none"></div>
    </section>

    <!-- FOOTER -->
    <%- include('partials/footer') %>

    <!-- TOAST NOTIFICATION PARA FEEDBACK DE COPIADO -->
    <div id="toast" class="toast-notification">
        <div class="w-8 h-8 bg-green-500/20 text-green-400 rounded-full flex items-center justify-center shadow-inner">
            <i class="fas fa-check text-xs"></i>
        </div>
        <div>
            <p id="toast-title" class="text-xs font-black text-white uppercase tracking-wider">¡Copiado!</p>
            <p id="toast-message" class="text-[11px] text-gray-400 font-medium">Elemento guardado en el portapapeles</p>
        </div>
    </div>

    <!-- SCRIPTS DINÁMICOS -->
    <script>
        function copyToClipboard(text, label) {
            navigator.clipboard.writeText(text).then(() => {
                showToast(`¡${label} Copiado!`, 'Se ha copiado al portapapeles sin espacios para facilitar tu banca móvil.');
            }).catch(err => {
                console.error('Error al copiar: ', err);
            });
        }

        function showToast(title, message) {
            const toast = document.getElementById('toast');
            document.getElementById('toast-title').textContent = title;
            document.getElementById('toast-message').textContent = message;
            
            toast.classList.add('show');
            
            setTimeout(() => {
                toast.classList.remove('show');
            }, 3500);
        }
    </script>
</body>
</html>
