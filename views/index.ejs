        <!-- SCRIPT DEL CAROUSEL DE ANUNCIOS -->
        <script>
            // ----- Carousel State -----
            /** @type {number} */
            let currentSlideIndex = 0;
            /** @type {number | undefined} */
            let autoRotateInterval;
            /** @type {boolean} */
            let isCarouselInitialized = false;

            /**
             * ----- Show Slide Logic -----
             * @param {number} index
             * @param {'next'|'prev'} direction
             */
            function showSlide(index, direction = 'next') {
                const slides = document.querySelectorAll('.announcement-slide');
                const prevBtn = document.getElementById('carousel-prev');
                const nextBtn = document.getElementById('carousel-next');

                if (!slides.length) return;

                if (!isCarouselInitialized) {
                    isCarouselInitialized = true;
                    currentSlideIndex = 0;

                    // ----- Initialize Controls -----
                    prevBtn.className = "absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm border border-white/30 text-white hover:bg-white/40 flex items-center justify-center focus:outline-none transition z-20 cursor-pointer shadow-md opacity-0 pointer-events-none";
                    nextBtn.className = "absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm border border-white/30 text-white hover:bg-white/40 flex items-center justify-center focus:outline-none transition z-20 cursor-pointer shadow-md";
                    return;
                }

                const outgoingIndex = currentSlideIndex;
                currentSlideIndex = index;

                if (outgoingIndex === index) {
                    return;
                }

                const outgoingSlide = slides[outgoingIndex];
                const incomingSlide = slides[index];

                // ----- Reset Transition Classes -----
                outgoingSlide.classList.remove('slide-3d-active', 'slide-3d-left', 'slide-3d-right');
                incomingSlide.classList.remove('slide-3d-active', 'slide-3d-left', 'slide-3d-right');

                if (direction === 'next') {
                    // ----- Next Transition -----
                    outgoingSlide.classList.add('slide-3d-left');
                    incomingSlide.classList.add('slide-3d-right');
                    void incomingSlide.offsetWidth;
                    incomingSlide.classList.remove('slide-3d-right');
                    incomingSlide.classList.add('slide-3d-active');
                } else {
                    // ----- Prev Transition -----
                    outgoingSlide.classList.add('slide-3d-right');
                    incomingSlide.classList.add('slide-3d-left');
                    void incomingSlide.offsetWidth;
                    incomingSlide.classList.remove('slide-3d-left');
                    incomingSlide.classList.add('slide-3d-active');
                }

                // ----- Update Arrow Visibility -----
                const isDarkBackground = index === 0;

                if (isDarkBackground) {
                    prevBtn.className = "absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm border border-white/30 text-white hover:bg-white/40 flex items-center justify-center focus:outline-none transition z-20 cursor-pointer shadow-md opacity-0 pointer-events-none";
                    nextBtn.className = "absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm border border-white/30 text-white hover:bg-white/40 flex items-center justify-center focus:outline-none transition z-20 cursor-pointer shadow-md";
                } else {
                    prevBtn.className = "absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-purple-100 hover:bg-purple-200 border border-purple-200/50 text-purple-700 flex items-center justify-center focus:outline-none transition z-20 cursor-pointer shadow-md";
                    nextBtn.className = "absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-purple-100 hover:bg-purple-200 border border-purple-200/50 text-purple-700 flex items-center justify-center focus:outline-none transition z-20 cursor-pointer shadow-md opacity-0 pointer-events-none";
                }
            }

            function nextSlide() {
                const slides = document.querySelectorAll('.announcement-slide');
                if (!slides.length) return;
                const nextIndex = (currentSlideIndex + 1) % slides.length;
                showSlide(nextIndex, 'next');
                resetAutoRotate();
            }

            function prevSlide() {
                const slides = document.querySelectorAll('.announcement-slide');
                if (!slides.length) return;
                const prevIndex = (currentSlideIndex - 1 + slides.length) % slides.length;
                showSlide(prevIndex, 'prev');
                resetAutoRotate();
            }

            function startAutoRotate() {
                clearInterval(autoRotateInterval);
                autoRotateInterval = setInterval(() => {
                    const slides = document.querySelectorAll('.announcement-slide');
                    if (!slides.length) return;
                    const nextIndex = (currentSlideIndex + 1) % slides.length;
                    const direction = nextIndex === 0 ? 'prev' : 'next';
                    showSlide(nextIndex, direction);
                }, 5000);
            }

            function resetAutoRotate() {
                clearInterval(autoRotateInterval);
                startAutoRotate();
            }

            // ----- Initialization -----
            document.addEventListener('DOMContentLoaded', () => {
                showSlide(0);
                startAutoRotate();

                // ----- Hover Pause Logic -----
                const slider = document.getElementById('slide-carrera');
                if (slider && slider.parentElement) {
                    const container = slider.parentElement;
                    container.addEventListener('mouseenter', () => clearInterval(autoRotateInterval));
                    container.addEventListener('mouseleave', startAutoRotate);
                }
            });
        </script>

