<!DOCTYPE html>
<html lang="es">

<head>
    <%- include('partials/head', { title: 'Comedor de los Pobres' ,
        description: 'Asociación Juan XXIII - Comedor de los Pobres P. Roberto Infante en Nuevo León. Transformando vidas a través de la nutrición digna.'
        }) %>
        <style>
            .blob {
                position: absolute;
                width: 500px;
                height: 500px;
                background: linear-gradient(135deg, rgba(124, 58, 237, 0.2) 0%, rgba(249, 115, 22, 0.2) 100%);
                filter: blur(80px);
                border-radius: 50%;
                z-index: -1;
            }

            .btn-glow:hover {
                box-shadow: 0 0 20px rgba(249, 115, 22, 0.4);
            }

            /* ----- Carousel Slide Transitions ----- */
            .slide-3d {
                position: absolute;
                inset: 0;
                width: 100%;
                height: 100%;
                transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1);
            }

            .slide-3d-active {
                transform: translateX(0) scale(1);
                opacity: 1;
                z-index: 10;
                pointer-events: auto;
            }

            .slide-3d-right {
                transform: translateX(100%) scale(0.96);
                opacity: 0;
                z-index: 0;
                pointer-events: none;
            }

            .slide-3d-left {
                transform: translateX(-100%) scale(0.96);
                opacity: 0;
                z-index: 0;
                pointer-events: none;
            }
        </style>
</head>

<body class="overflow-x-hidden">

    <!-- NAVBAR -->
    <%- include('partials/navbar') %>

        <!-- Hero Section -->
        <section class="relative min-h-[90dvh] md:min-h-[90vh] flex items-center overflow-hidden py-12 sm:py-16 lg:py-0">
