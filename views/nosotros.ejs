<!DOCTYPE html>
<html lang="es">

<head>
    <%- include('partials/head', { title: 'Comedor de los Pobres - La Asociación' ,
        description: 'Conoce más sobre la Asociación Juan XXIII, nuestra historia, misión y el impacto de nuestros comedores comunitarios en Nuevo León.'
        }) %>
        <style>
            .soft-card {
                background: white;
                border-radius: 2.5rem;
                border: 1px solid rgba(0, 0, 0, 0.03);
                transition: transform 0.3s ease;
            }

            .value-tag {
                background: white;
                padding: 1rem 1.5rem;
                border-radius: 1.2rem;
                display: flex;
                align-items: center;
                gap: 0.75rem;
                font-weight: 700;
                font-size: 0.85rem;
                color: #475569;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
                border: 1px solid rgba(0, 0, 0, 0.03);
            }

            .hero-visual {
                background: linear-gradient(135deg, #c27bf8 0%, #946ed6 100%);
                min-height: 35vh;
                display: flex;
                align-items: center;
                position: relative;
                overflow: hidden;
                border-radius: 0 0 4rem 4rem;
                box-shadow: 0 10px 30px rgba(124, 58, 237, 0.25);
                border-bottom: 1px solid rgba(124, 58, 237, 0.1);
            }

            .hero-pattern {
                position: absolute;
                inset: 0;
                opacity: 0.1;
                background-image: radial-gradient(#ffffff 1px, transparent 1px);
                background-size: 30px 30px;
            }
        </style>
</head>

<body>

    <!-- NAVBAR -->
    <%- include('partials/navbar') %>

        <!-- HEADER -->
        <section class="hero-visual text-white">
            <div class="hero-pattern"></div>

            <!-- Círculos decorativos -->
            <div class="absolute -top-24 -left-24 w-96 h-96 bg-yellow-400/20 rounded-full blur-3xl"></div>
            <div class="absolute top-1/2 -right-24 w-64 h-64 bg-orange-500/20 rounded-full blur-3xl"></div>

            <div class="max-w-7xl mx-auto px-6 w-full text-center relative z-10 py-8">
                <h1 class="text-4xl md:text-5xl font-black mb-6">
                    Una misión que nos define
                </h1>
                <p class="text-lg text-purple-100 max-w-2xl mx-auto leading-relaxed opacity-90">
                    Conoce la historia, los valores y el corazón de Juan XXIII al Servicio de los Pobres A.C.
                </p>
            </div>
        </section>

        <!-- MISIÓN Y VISIÓN -->
        <section class="pt-12 pb-8">
            <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-6">
                <!-- Misión -->
                <div class="soft-card p-6 md:p-8 shadow-sm flex gap-4 items-start">
                    <div
                        class="w-10 h-10 bg-purple-100 text-purple-600 rounded-xl flex items-center justify-center shrink-0 mt-1">
                        <i class="fas fa-bullseye text-lg"></i>
                    </div>
                    <div class="flex-1">
                        <h2 class="text-xl font-black text-purple-900 mb-1 tracking-tight">Misión</h2>
                        <p class="text-gray-500 leading-relaxed text-base">
                            Contribuir a disminuir la pobreza alimentaria brindando una comida gratuita al día, seis
                            días
                            a la semana, a personas en situación vulnerable, en un espacio digno y sin distinción
                            alguna.
                        </p>
                    </div>
                </div>

                <!-- Visión -->
                <div class="soft-card p-6 md:p-8 shadow-sm flex gap-4 items-start">
                    <div
                        class="w-10 h-10 bg-orange-100 text-orange-500 rounded-xl flex items-center justify-center shrink-0 mt-1">
                        <i class="fas fa-eye text-lg"></i>
                    </div>
                    <div class="flex-1">
                        <h2 class="text-xl font-black text-purple-900 mb-1 tracking-tight">Visión</h2>
                        <p class="text-gray-500 leading-relaxed text-base">
                            Ser una organización nacional que edifique Comedores, en cada lugar de la República
                            Mexicana,
                            para proveer de alimento a personas en situación de vulnerabilidad.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- HISTORIA / LA ASOCIACIÓN -->
        <section class="py-24">
            <div class="max-w-7xl mx-auto px-6">
                <div class="grid lg:grid-cols-12 gap-16 items-start">

                    <!-- Imagen e Intro -->
                    <div class="lg:col-span-5 space-y-8">
                        <div class="relative">
                            <div class="aspect-[3/4] rounded-[3rem] overflow-hidden shadow-2xl">
                                <!-- Placeholder de la foto del Padre Infante -->
                                <img src="/imagenes/robertoInfante.jpg" class="w-full h-full object-cover"
                                    alt="Padre Roberto Infante">
                            </div>
                            <div
                                class="absolute -bottom-6 -right-6 bg-purple-600 text-white p-8 rounded-[2rem] shadow-xl max-w-[280px]">
                                <p class="text-xs font-bold uppercase tracking-widest opacity-80 mb-2">Fundador</p>
                                <p class="font-black text-lg leading-tight italic whitespace-nowrap">"Amar es servir"
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Texto de Historia -->
                    <div class="lg:col-span-7 space-y-8">
                        <div>
                            <h2 class="text-3xl font-black text-purple-900 mb-6">Nuestra Historia</h2>
                            <div class="space-y-6 text-gray-500 leading-relaxed text-sm">
                                <p>
                                    Nuestra asociación tuvo sus inicios desde el año <span
                                        class="font-bold text-purple-600">1961</span>, fecha en la cual el <span
                                        class="text-slate-800 font-bold">Padre Roberto Infante Castañeda</span> inició
                                    su
                                    proyecto para dar alimentos a los más desamparados, dando servicio en un comedor
                                    parroquial para pobres.
                                </p>
                                <p>
                                    Gracias a la gran labor altruista y al loable esfuerzo del Pbro. Roberto Infante
                                    Castañeda sigue dando servicio en la actualidad en cuatro (4) sedes en diferentes
                                    Municipios de Nuevo León.
                                </p>
                                <p>
                                    Un 27 de Junio de 1961, este comedor tuvo sus inicios en la Colonia Industrial en
                                    Monterrey, una de las más precarias de la ciudad. Al ver la vulnerabilidad de las
                                    personas, el Padre Infante decidió llevar a cabo lo que se convertiría en su obra
                                    más
                                    importante y por la que sería ampliamente recordado: la creación del COMEDOR DE LOS
                                    POBRES.
                                </p>
                                <p>
                                    El <span class="font-bold text-slate-800">29 de Octubre de 1969</span>, la
                                    asociación
                                    Juan XXIII al Servicio de los Pobres A.C. fue legalmente constituida.
                                </p>
                            </div>
                        </div>

                        <!-- Valores -->
                        <div class="pt-8 border-t border-gray-100">
                            <h3 class="text-sm font-black text-gray-400 uppercase tracking-[0.2em] mb-8">Nuestros
                                Valores
                            </h3>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div class="value-tag"><i class="fas fa-dove text-purple-400"></i> Espíritu de servicio
                                </div>
                                <div class="value-tag"><i class="fas fa-users text-purple-400"></i> Compromiso social
                                </div>
                                <div class="value-tag"><i class="fas fa-hand-holding-heart text-purple-400"></i> Respeto
                                    a
                                    la dignidad</div>
                                <div class="value-tag"><i class="fas fa-check-circle text-purple-400"></i> Honestidad e
                                    Integridad</div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- BANNER DE CIERRE -->
        <section class="pb-24 bg-white">
            <div class="max-w-7xl mx-auto px-6">
                <div
                    class="bg-purple-900 rounded-[3rem] p-8 md:p-16 relative overflow-hidden flex flex-col md:flex-row items-center justify-between text-center md:text-left">
                    <div class="relative z-10">
                        <h3 class="text-2xl md:text-3xl font-black text-white mb-2">Sé parte de esta historia</h3>
                        <p class="text-purple-200">Tu apoyo permite que la obra del Padre Infante siga viva.</p>
                    </div>
                    <div class="mt-8 md:mt-0 relative z-10">
                        <a href="/contactanos"
                            class="px-10 py-4 bg-orange-500 text-white rounded-full font-black text-sm hover:bg-orange-600 transition shadow-2xl inline-block">SUMARME
                            COMO VOLUNTARIO</a>
                    </div>
                    <!-- Decoración -->
                    <div class="absolute top-0 right-0 w-64 h-64 bg-purple-800 rounded-full -mr-20 -mt-20 opacity-50">
                    </div>
                    <div class="absolute bottom-0 left-0 w-40 h-40 bg-purple-700 rounded-full -ml-10 -mb-10 opacity-30">
                    </div>
                </div>
            </div>
        </section>

        <!-- FOOTER -->
        <%- include('partials/footer') %>
</body>

</html>