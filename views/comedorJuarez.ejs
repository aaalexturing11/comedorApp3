                <p>© 2024 Juan XXIII al Servicio de los Pobres A.C.</p>
                <div class="flex space-x-6">
                    <a href="#" class="hover:text-purple-600">Privacidad</a>
                    <a href="#" class="hover:text-purple-600">Términos</a>
                    <a href="#" class="hover:text-purple-600">Voluntariado</a>
                </div>
            </div>
        </div>
    </footer>

    <script>
        (function () {
            var root = document.getElementById('mobile-menu');
            var toggle = document.getElementById('mobile-menu-toggle');
            var backdrop = document.getElementById('mobile-menu-backdrop');
            var panel = document.getElementById('mobile-menu-panel');
            if (!root || !toggle || !backdrop || !panel) return;

            var openIcon = toggle.querySelector('.icon-open');
            var closeIcon = toggle.querySelector('.icon-close');
            var links = root.querySelectorAll('a');

            function setOpen(open) {
                root.classList.toggle('pointer-events-none', !open);
                root.setAttribute('aria-hidden', open ? 'false' : 'true');
                toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
                toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
                document.body.classList.toggle('overflow-hidden', open);

                backdrop.classList.toggle('opacity-0', !open);
                backdrop.classList.toggle('opacity-100', open);

                panel.classList.toggle('-translate-y-full', !open);
                panel.classList.toggle('translate-y-0', open);

                if (openIcon && closeIcon) {
                    openIcon.classList.toggle('hidden', open);
                    closeIcon.classList.toggle('hidden', !open);
                }
            }

            toggle.addEventListener('click', function () {
                setOpen(toggle.getAttribute('aria-expanded') !== 'true');
            });

            backdrop.addEventListener('click', function () {
                setOpen(false);
            });

            links.forEach(function (a) {
                a.addEventListener('click', function () {
                    setOpen(false);
                });
            });

            root.querySelectorAll('form').forEach(function (f) {
                f.addEventListener('submit', function () {
                    setOpen(false);
                });
            });

            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') setOpen(false);
            });
        })();
    </script>
</body>
</html>