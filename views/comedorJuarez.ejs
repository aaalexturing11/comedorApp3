<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head', { 
        title: 'Comedor de los Pobres - Juárez', 
        description: 'Conoce el Comedor Juan XXIII en Juárez, N.L. Brindamos alimento y esperanza a quienes más lo necesitan.' 
    }) %>
    <style>
        :root {
            --morado: #7c3aed;
            --amarillo: #fbbf24;
            --naranja: #f97316;
        }

        /* Hero Ultra Moderno */
        .hero-visual {
            background: linear-gradient(135deg, #c27bf8 0%, #946ed6 100%);
            min-height: 70vh;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
        }

        .hero-pattern {
            position: absolute;
            inset: 0;
            opacity: 0.1;
            background-image: radial-gradient(#ffffff 1px, transparent 1px);
            background-size: 30px 30px;
        }

        .hero-image-card {
            transform: perspective(1000px) rotateY(-15deg) rotateX(5deg);
            box-shadow: -20px 20px 50px rgba(0,0,0,0.3);
            transition: all 0.5s ease;
        }

        .hero-image-card:hover {
            transform: perspective(1000px) rotateY(0deg) rotateX(0deg);
        }

        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            grid-auto-rows: 240px;
            gap: 1.5rem;
        }

        .gallery-item:nth-child(2) { grid-column: span 2; }
        .gallery-item:nth-child(3) { grid-row: span 2; }

        @media (max-width: 768px) {
            .gallery-grid { grid-template-columns: 1fr; grid-auto-rows: 250px; }
            .gallery-item { grid-column: span 1 !important; grid-row: span 1 !important; }
            .hero-image-card { transform: none; }
        }

        .accent-border {
            border-left: 6px solid var(--naranja);
        }

        .glass-nav {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(124, 58, 237, 0.1);
        }

        #mobile-menu-panel {
            -webkit-overflow-scrolling: touch;
        }
    </style>
</head>
<body class="bg-white font-sans text-gray-800">

    <!-- NAVBAR -->
    <!-- NAVBAR -->
    <%- include('partials/navbar') %>

    <!-- HERO -->
    <section class="hero-visual text-white">
        <div class="hero-pattern"></div>
        
        <!-- Círculos decorativos -->
        <div class="absolute -top-24 -left-24 w-96 h-96 bg-yellow-400/20 rounded-full blur-3xl"></div>
        <div class="absolute top-1/2 -right-24 w-64 h-64 bg-orange-500/20 rounded-full blur-3xl"></div>

        <div class="max-w-7xl mx-auto px-6 w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center relative z-10">
            <div>
                <h1 class="text-6xl lg:text-8xl font-black leading-none mb-6">
                    Sede <br>
                    <span id="sede-titulo" class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-400 to-orange-500">Juarez</span>
                </h1>
                <p id="sede-subtitulo" class="text-xl text-purple-100 max-w-lg leading-relaxed opacity-90">
                    Sirviendo con amor y dignidad en el corazón de Nuevo León.
                </p>
            </div>
            
            <div class="hidden lg:block">
                <div class="hero-image-card rounded-[3rem] overflow-hidden border-4 border-white/20">
                    <img id="sede-hero-img" src="/imagenes/Comedor Juarez/CJ.1.jpg" alt="Comedor" class="w-full aspect-video object-cover">
                </div>
            </div>
        </div>
    </section>

    <!-- Información de Sede -->
